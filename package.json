{
  "name": "@ardurai/article-synthesizer",
  "version": "0.1.0",
  "private": false,
  "description": "Copyright-safe original article synthesis from Top-10 topics + clustered sources for the Ardur AI content pipeline (stage 4)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types src/smoke.test.ts",
    "synthesize": "node --experimental-strip-types src/cli.ts"
  },
  "keywords": [
    "ardur",
    "article",
    "synthesis",
    "copyright-safe",
    "provenance",
    "content-pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ArdurAI/ardur-article-synthesizer.git"
  },
  "dependencies": {
    "@ardurai/contracts": "github:ArdurAI/ardur-contracts#4a47ec8",
    "jsonrepair": "^3.14.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
