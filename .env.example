# Ardur content pipeline — environment defaults
# Cost-guarded, pluggable AI provider. Default is the deterministic, zero-cost path.
#
# Provider auto-detection precedence:
#   1. Ollama Cloud  — set OLLAMA_API_KEY  → https://ollama.com, model gpt-oss:120b
#   2. Local Ollama  — set OLLAMA_HOST     → POST /api/generate at that address
#   3. Deterministic — (no keys set)       → rules-based, zero cost, articles held
#
# NEVER commit a real key. Load from your OS keychain at runtime:
#   export OLLAMA_API_KEY=$(security find-generic-password -s ardur-ollama -w)

# Explicit override (optional — auto-detection handles the common cases)
# ARDUR_AI_PROVIDER=deterministic   # deterministic | ollama | openai

# Hard kill switch: set to 0 to force deterministic regardless of keys
ARDUR_AI_ENABLED=1
# Per-run generation budget; deterministic fallback after this many model calls
ARDUR_AI_MAX_GENERATIONS=20
# Per-call timeout (ms) before falling back to deterministic
ARDUR_AI_TIMEOUT_MS=20000

# Ollama Cloud — PRIMARY writer (https://ollama.com)
# Key is loaded from OS keychain at runtime — never commit it.
# OLLAMA_API_KEY=<load from keychain>
# OLLAMA_MODEL=gpt-oss:120b   # optional override; default is gpt-oss:120b

# Local Ollama (fallback when OLLAMA_API_KEY is not set)
# OLLAMA_HOST=http://127.0.0.1:11434

# OpenAI (optional explicit provider)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
